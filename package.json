{
  "name": "claude-plus-plus",
  "private": true,
  "version": "1.0.1",
  "type": "module",
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=22",
    "npm": ">=10"
  },
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit --pretty false",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "audit:claude-zh": "node .workbench/tools/audit-claude-zh-visible.cjs",
    "check:rust": "cargo check --manifest-path src-tauri/Cargo.toml",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml --lib",
    "tauri:build:macos": "tauri build --bundles dmg --no-sign",
    "tauri:build:macos:arm64": "tauri build --bundles dmg --target aarch64-apple-darwin --no-sign",
    "tauri:build:macos:x64": "tauri build --bundles dmg --target x86_64-apple-darwin --no-sign",
    "tauri": "tauri"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "lucide-react": "^0.468.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
